# Development defaults
EXPO_PUBLIC_ROUTING_BASE_URL=http://localhost:3000
EXPO_PUBLIC_MAP_STYLE_URL=https://api.maptiler.com/maps/streets-v2/style.json?key=YOUR_MAPTILER_KEY
EXPO_PUBLIC_MAP_TILE_ENDPOINT=https://api.maptiler.com/tiles/v3/{z}/{x}/{y}.pbf?key=YOUR_MAPTILER_KEY

# Backward-compatible aliases
ROUTING_BASE_URL=http://localhost:3000
MAP_STYLE_URL=https://api.maptiler.com/maps/streets-v2/style.json?key=YOUR_MAPTILER_KEY
MAP_TILE_ENDPOINT=https://api.maptiler.com/tiles/v3/{z}/{x}/{y}.pbf?key=YOUR_MAPTILER_KEY

MOCK_MODE=true
